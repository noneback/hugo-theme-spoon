baseURL: https://example.com/
title: My Blog
theme: hugo-theme-spoon
defaultContentLanguage: en
enableRobotsTXT: true
hasCJKLanguage: true

pagination:
  pagerSize: 10

markup:
  highlight:
    lineNos: false
    noClasses: false

params:
  description: A personal blog powered by Hugo Theme Spoon
  brand: HOME
  avatarURL: /images/avatar.png
  favicon: /images/favicon.ico
  author: Your Name
  authorDescription: Your short introduction
  info: Notes about technology and life
  darkModeTheme: data-dark-mode # or icy-dark-mode

  options:
    showDarkMode: true
    enableImgZooming: true
    enableMultiLang: true
    showMetaTags: true

  article:
    toc: true
    related: true
    comments: true
    readingProgress: true
    imageZoom: true

  guestbook:
    title: Guestbook
    description: Leave a comment below.

  comments:
    giscus:
      enable: false
      repo: username/repository
      repo_id: R_xxx
      category: Announcements
      category_id: DIC_xxx
      mapping: pathname
      position: top
      lang: en
    utteranc:
      enable: false
      repo: username/repository
      issueTerm: pathname

  analytics:
    google:
      SiteVerificationTag: ""
    umami:
      enable: false
      website_id: ""
      url: https://analytics.example.com/script.js

  social:
    - name: GitHub
      pre: >-
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"></path></svg>
      url: https://github.com/username

languages:
  en:
    label: English
    menu:
      main:
        - name: Blog
          url: /blog
          weight: 1
        - name: Tags
          url: /tags
          weight: 2
        - name: Archive
          url: /archives
          weight: 3
        - name: Guestbook
          url: /guestbook
          weight: 4
  zh:
    label: 中文
    params:
      author: 你的名字
      authorDescription: 你的简介
      info: 关于这个博客的介绍
      guestbook:
        title: 留言板
        description: 欢迎留下你的评论。
    menu:
      main:
        - name: 文章
          url: /blog
          weight: 1
        - name: 标签
          url: /tags
          weight: 2
        - name: 归档
          url: /archives
          weight: 3
        - name: 留言板
          url: /guestbook
          weight: 4

taxonomies:
  series: series
  tag: tags
